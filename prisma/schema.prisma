generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider   = "postgresql"
  url        = env("DATABASE_URL")
  directUrl  = env("DIRECT_URL")
}

model MarketSnapshot {
  id              String   @id @default(cuid())
  timestamp       DateTime @default(now())
  totalMarketCap  Float
  totalVolume24h  Float
  btcDominance    Float
  ethDominance    Float
  usdtDominance   Float
  bnbDominance    Float
  othersDominance Float
  totalExBtc      Float
  totalExTop10    Float

  @@index([timestamp])
}

model User {
  id             String          @id @default(cuid())
  name           String
  family         String
  email          String          @unique
  password       String
  watchlist      WatchlistItem[]
  chartDrawings  ChartDrawing[]
}

model WatchlistItem {
  id     String @id @default(cuid())
  userId String
  symbol String
  name   String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, symbol])
}

model ChartDrawing {
  id     String @id @default(cuid())
  userId String
  coinId String
  hlines Json   @default("[]")
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, coinId])
}
